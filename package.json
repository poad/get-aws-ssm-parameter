{
  "name": "get-aws-ssm-parameter",
  "version": "3.1.0",
  "private": true,
  "description": "Get AWS SSM Parameter action",
  "type": "module",
  "main": "lib/main.js",
  "scripts": {
    "build": "swc --delete-dir-on-start --extensions .ts src -d lib --strip-leading-paths",
    "clean": "rm -rf dist lib",
    "lint": "eslint",
    "lint-fix": "eslint --fix",
    "package": "ncc build --license licenses.txt -m -q --target es2023",
    "test": "vitest run",
    "all": "pnpm build && pnpm package"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/actions/typescript-action.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@aws-sdk/client-ssm": "^3.1039.0",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.32",
    "@swc/helpers": "^0.5.21",
    "@types/node": "^25.6.0",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^10.2.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-promise": "^7.3.0",
    "jiti": "^2.6.1",
    "js-yaml": "^4.1.1",
    "regenerator-runtime": "^0.14.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "engines": {
    "npm": "use pnpm please!",
    "yarn": "use pnpm please!",
    "pnpm": ">=10.22.0",
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.0.5"
}
