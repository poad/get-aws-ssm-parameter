{
  "name": "get-aws-ssm-parameter",
  "version": "3.1.0",
  "private": true,
  "description": "Get AWS SSM Parameter action",
  "type": "module",
  "main": "lib/main.js",
  "scripts": {
    "build": "swc --delete-dir-on-start --extensions .ts src -d lib --strip-leading-paths",
    "clean": "rm -rf dist lib",
    "lint": "eslint",
    "lint-fix": "eslint --fix",
    "package": "ncc build --license licenses.txt -m -q --target es2023",
    "test": "vitest run",
    "all": "pnpm build && pnpm package"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/actions/typescript-action.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@aws-sdk/client-ssm": "^3.1075.0",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@swc/helpers": "^0.5.23",
    "@types/node": "^25.9.4",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^10.5.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-promise": "^7.3.0",
    "jiti": "^2.7.0",
    "js-yaml": "^4.2.0",
    "regenerator-runtime": "^0.14.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.7.0",
      "onFail": "download"
    }
  }
}
